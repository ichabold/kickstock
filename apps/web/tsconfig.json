{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@kickstock/types": [
        "../../packages/types/src/index.ts"
      ],
      "@kickstock/constants": [
        "../../packages/constants/src/index.ts"
      ],
      "@kickstock/game-engine": [
        "../../packages/game-engine/src/index.ts"
      ],
      "@kickstock/i18n": [
        "../../packages/i18n/index.ts"
      ],
      "@kickstock/i18n/locales/*": [
        "../../packages/i18n/locales/*"
      ]
    },
    "allowJs": true,
    "noEmit": true,
    "isolatedModules": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
