# KickStock — Variables d'environnement (Phase 1 : tout local, pas de secrets nécessaires)
# Pour la Phase 2, remplis ces valeurs depuis ton dashboard Supabase

# ── Supabase (staging) ────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://TON-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # NE JAMAIS METTRE CÔTÉ CLIENT

# ── Redis / Upstash (Phase 2) ────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ── Email / Resend (Phase 2) ──────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Cloudflare Turnstile (anti-bot guest creation) ───────────────────────────
# Obtenir sur https://dash.cloudflare.com → Turnstile → Add site (invisible widget)
# Laisser vide en dev local pour bypasser la vérification
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Sentry (monitoring erreurs runtime) ──────────────────────────────────────
# Créer un projet sur https://sentry.io → Settings → Projects → DSN
# Laisser vide en dev local pour désactiver Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=ton-org
SENTRY_PROJECT=kickstock

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
