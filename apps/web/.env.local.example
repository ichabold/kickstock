# KickStock — Variables d'environnement (Phase 1 : tout local, pas de secrets nécessaires)
# Pour la Phase 2, remplis ces valeurs depuis ton dashboard Supabase

# ── Supabase (staging) ────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://TON-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # NE JAMAIS METTRE CÔTÉ CLIENT

# ── Redis / Upstash (Phase 2) ────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ── Email / Resend (Phase 2) ──────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
